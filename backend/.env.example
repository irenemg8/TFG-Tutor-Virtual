# Copy this file to .env and fill in the sensitive values.
# Never commit .env (it's in .gitignore).
#
# 🔧 Stack post-migración (abril 2026):
#   - PostgreSQL es la única BD soportada (Mongo eliminado).
#   - LLM_MODE=upv usa el cluster Ollama de la UPV; LLM_MODE=local usa Ollama
#     nativo en :11434 (típicamente para tests offline).

# ------------------------
# Database (PostgreSQL — única fuente)
# ------------------------
DATABASE_TYPE=postgresql
# Local Linux dev: postgresql://tutor:tutor_dev@localhost:5435/tutorvirtual
# Producción Windows: postgresql://postgres:CHANGEME@127.0.0.1:5432/tutorvirtual
PG_CONNECTION_STRING=

# ------------------------
# General
# ------------------------
# Local Linux: 3030 (Vicente). Producción Windows: 3001 (nginx → :3001).
PORT=3001
NODE_ENV=production
# Random long string — rotate if leaked
SESSION_SECRET=

# Public URL del servidor (usado para redirects). En local: http://localhost:3030.
SERVER_BASE_URL=https://tutor-virtual.dsic.upv.es/v2

# ------------------------
# Frontend (CORS y redirects)
# ------------------------
# Local: http://localhost:5173 (Vite dev). Producción: el dominio UPV.
FRONTEND_BASE_URL=https://tutor-virtual.dsic.upv.es/v2
# Workflow debug UI (sólo dev). Producción puede dejarlo vacío.
WORKFLOW_BASE_URL=http://localhost:5174

# ------------------------
# Ollama
# ------------------------
LLM_MODE=upv
OLLAMA_API_URL_UPV=https://ollama.gti-ia.upv.es:443
OLLAMA_API_URL_LOCAL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0.4
HISTORY_MAX_MESSAGES=6
OLLAMA_KEEP_ALIVE=60m
OLLAMA_STREAM_MAX_MS=1800000
OLLAMA_TIMEOUT_MS=180000
OLLAMA_CLASSIFIER_MODEL=qwen2.5:latest
OLLAMA_CLASSIFIER_TIMEOUT_MS=120000
# 1 sólo si UPV cambia a self-signed (hoy el cert es válido).
OLLAMA_INSECURE_TLS=0

# ------------------------
# Chroma
# ------------------------
CHROMA_URL=http://localhost:8000

# ------------------------
# Debug / observability
# ------------------------
DEBUG_OLLAMA=1
DEBUG_PIPELINE=1
AUDIT_LOG=1
DEBUG_DUMP_CONTEXT=0
# Absolute path for raw prompt/message dumps when DEBUG_DUMP_CONTEXT=1.
# Linux: /tmp/tutor_virtual_debug. Windows: C:\Users\admin\tutor_virtual_debug
DEBUG_DUMP_PATH=

# ------------------------
# Hexagonal refactor (orchestrator + budget P1c)
# ------------------------
USE_ORCHESTRATOR=1
ORCHESTRATOR_BUDGET_MS=45000
GUARDRAIL_BUDGET_MS=45000
GUARDRAIL_MIN_RETRY_BUDGET_MS=10000

# ------------------------
# CAS OAuth2
# ------------------------
CAS_BASE_URL=https://caspre.upv.es/cas
OAUTH_CLIENT_ID=TUTOR-VIRTUAL
# Provided by the CAS administrator
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://tutor-virtual.dsic.upv.es/v2/api/auth/cas/callback
OAUTH_SCOPES=profile email

# ------------------------
# Production with CAS
# ------------------------
# Set to "true" only in local development; never in production.
# El backend aborta si DEV_BYPASS_AUTH=true && NODE_ENV=production.
DEV_BYPASS_AUTH=false
