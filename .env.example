# ============================================================
#  Plantilla de variables para Dokploy (pestaña Environment).
#  NO pongas aquí valores reales ni subas este fichero relleno.
#  Copia este contenido en Dokploy y rellena los <...>.
#
#  Las que tienen "?" en el compose son OBLIGATORIAS:
#    PG_PASSWORD, SESSION_SECRET, POLIGPT_API_KEY, OAUTH_CLIENT_SECRET
# ============================================================

# --- PostgreSQL ---
PG_USER=postgres
PG_PASSWORD=<password_nueva_solo_alfanumerica>
PG_DB=tutorvirtual

# --- General ---
SESSION_SECRET=<cadena_larga_aleatoria_64+>
SERVER_BASE_URL=https://tutor-socratico.gnd.upv.es
FRONTEND_BASE_URL=https://tutor-socratico.gnd.upv.es

# --- LLM: PoliGPT ---
LLM_PROVIDER=poligpt
EMBEDDING_PROVIDER=openai
POLIGPT_BASE_URL=https://api.poligpt.upv.es
POLIGPT_API_KEY=<tu_api_key_poligpt>
POLIGPT_MODEL=qwen2.5vl:32b
POLIGPT_EMBED_MODEL=nomic-embed-text

# --- Ollama (modo upv / fallback) ---
LLM_MODE=upv
OLLAMA_API_URL_UPV=https://ollama.gti-ia.upv.es:443

# --- Orquestador ---
USE_ORCHESTRATOR=1
ORCHESTRATOR_STREAM_TOKENS=1
AUDIT_LOG=1

# --- CAS OAuth2 (callback en la raíz, sin /v2) ---
CAS_BASE_URL=https://caspre.upv.es/cas
OAUTH_CLIENT_ID=TUTOR-VIRTUAL
OAUTH_CLIENT_SECRET=<secreto_cas_del_panel_de_dennis>
OAUTH_REDIRECT_URI=https://tutor-socratico.gnd.upv.es/api/auth/cas/callback
OAUTH_SCOPES=profile email

# --- Export de interacciones ---
EXPORT_TOKEN=<token_export>

# --- Build del frontend (raíz "/") ---
VITE_BASE_PATH=
VITE_BACKEND_URL=
VITE_DEV_BYPASS_AUTH=false
