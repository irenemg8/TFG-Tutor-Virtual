# Copy this file to .env and fill in the values before running docker compose.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# Public URL where the app is reachable (used for CORS and CAS redirect)
# Domain used by Traefik routing (without https://)
DOMAIN=your-domain.upv.es

FRONTEND_BASE_URL=https://your-domain.upv.es
SERVER_BASE_URL=https://your-domain.upv.es

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Set DATABASE_TYPE to "mongodb" (default) or "postgresql"
DATABASE_TYPE=mongodb

# MongoDB — leave as-is to use the compose mongodb service,
# or replace with your Atlas connection string.
MONGODB_URI=mongodb://mongodb:27017/tutor-virtual

# PostgreSQL — only needed when DATABASE_TYPE=postgresql
# PG_CONNECTION_STRING=postgresql://user:password@host:5432/dbname

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
# Generate a strong random string, e.g.: openssl rand -hex 32
SESSION_SECRET=change-me-use-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# LLM / Ollama
# ---------------------------------------------------------------------------
# "local" = use the ollama compose service
# "upv"   = use the university's remote Ollama instance
LLM_MODE=local

# Used when LLM_MODE=local (docker service name resolves automatically in compose)
OLLAMA_API_URL_LOCAL=http://host-docker-internal:11434

# Used when LLM_MODE=upv
OLLAMA_API_URL_UPV=

OLLAMA_MODEL=qwen2.5:latest
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_TEMPERATURE=0.4
OLLAMA_KEEP_ALIVE=60m
OLLAMA_TIMEOUT_MS=180000
OLLAMA_STREAM_MAX_MS=1800000

OLLAMA_CLASSIFIER_MODEL=qwen2.5:latest
OLLAMA_CLASSIFIER_TIMEOUT_MS=120000

# Set to 1 if the UPV Ollama endpoint uses a self-signed certificate
OLLAMA_INSECURE_TLS=0

# ---------------------------------------------------------------------------
# ChromaDB (vector store for RAG)
# ---------------------------------------------------------------------------
CHROMA_URL=http://chromadb:8000

# ---------------------------------------------------------------------------
# CAS OAuth2 (UPV single sign-on)
# Leave blank to use DEV_BYPASS_AUTH instead during local testing
# ---------------------------------------------------------------------------
CAS_BASE_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://your-domain.upv.es/auth/callback
OAUTH_SCOPES=profile email

# ---------------------------------------------------------------------------
# Development flags — MUST be "false" in production
# ---------------------------------------------------------------------------
DEV_BYPASS_AUTH=false
DEBUG_OLLAMA=0
DEBUG_DUMP_CONTEXT=0
