# Copy this file to .env and adjust for your environment.
# Never commit .env (it's in .gitignore).

# Base path where the SPA is mounted (matches nginx location)
VITE_BASE_PATH=/v2

# Backend API base path (served behind the same nginx location)
VITE_BACKEND_URL=/v2

# Set to "true" ONLY in local development to bypass CAS auth.
# Must be "false" in production.
VITE_DEV_BYPASS_AUTH=false
